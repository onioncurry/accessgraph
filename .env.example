# AccessGraph — environment variables
# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# Optional: Crustdata API for enriching people profiles (Person 3 stretch goal).
# NOTE: the key that was pasted in team chat should be treated as exposed —
# rotate it after the hackathon.
CRUSTDATA_API_KEY=

# Optional: Google Drive permissions API (Person 3 stretch goal — real
# current_access instead of mock data).
GOOGLE_APPLICATION_CREDENTIALS=

# Person 1 (Slack front door) — only if the real Slack app is wired up.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
