# AccessGraph — environment variables
# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# Optional: Crustdata API for live people/company enrichment
# (the repo ships cached pulls, so everything works without a key).
CRUSTDATA_API_KEY=

# Optional: Google Drive permissions API (production path — real
# current_access instead of the in-repo graph).
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: real Slack app front door.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
